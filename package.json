{
  "name": "notemaxxing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-build-info.js && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "precommit": "npm run lint && npm run type-check && npm run test",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "import": "tsx scripts/import-content.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.532.0",
    "next": "15.5.20",
    "next-themes": "0.4.6",
    "postgres": "3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@eslint/eslintrc": "3.2.0",
    "@tailwindcss/postcss": "4.1.6",
    "@types/node": "20.17.15",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.19.0",
    "eslint-config-next": "15.5.20",
    "husky": "9.1.7",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.6",
    "tsx": "4.23.1",
    "typescript": "5.7.3",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "app/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "lib/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "components/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
